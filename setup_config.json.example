  "_workstation_profiles_comment": "Pre-baked combos for common machine roles. categories pulls in every app in those categories; extra_apps adds named apps from other categories (e.g. VJ rig wants Traktor for beatmatching even though Traktor is an Audio app).",
  "workstation_profiles": [
    {
      "name": "VJ rig",
      "description": "Live video performance + beatmatching",
      "categories": ["General", "Visual", "RealTime"],
      "extra_apps": ["Traktor Pro"]
    },
    {
      "name": "Audio rig",
      "description": "Music production / DJ workstation",
      "categories": ["General", "Audio"],
      "extra_apps": []
    },
    {
      "name": "3D rig",
      "description": "Modeling, rendering, 3D printing",
      "categories": ["General", "Visual", "Physical"],
      "extra_apps": []
    },
    {
      "name": "Photo rig",
      "description": "RAW developing + light editing",
      "categories": ["General", "Photo"],
      "extra_apps": ["Affinity"]
    },
    {
      "name": "Web rig",
      "description": "Web development workstation",
      "categories": ["General", "Web"],
      "extra_apps": ["Sublime Text"]
    },
    {
      "name": "Office laptop",
      "description": "Lightweight machine, just the essentials",
      "categories": ["General"],
      "extra_apps": []
    },
    {
      "name": "Everything",
      "description": "Kitchen-sink workstation - all categories",
      "categories": ["General", "Visual", "RealTime", "Audio", "Physical", "Photo", "Media", "Web"],
      "extra_apps": []
    }
  ],

  "pipeline_config": {
    "work_drive": "I:",
    "active_base": "D:\\_work\\Active",
    "archive_base": "D:\\_work\\Archive",
    "mapped_software_path": "P:\\Software",
    "launchers_base_path": "P:\\Launchers"
  }
}
