{
  "_comment": "New PC Setup Configuration - Copy to setup_config.json and edit paths to match your system",

  "_drive_mappings_comment": "Virtual drives created via 'subst'. 'label' is the Explorer display name - cosmetic only, written to HKCU\\...\\Explorer\\DriveIcons\\<letter>\\DefaultLabel (same key Visual Subst uses, so they stay in sync). 'registry_name' is optional and defaults to SubstDrive_<letter> for the HKCU\\...\\Run autorun entry.",
  "drive_mappings": [
    {
      "drive_letter": "I:",
      "target_path": "D:\\_work\\Active",
      "label": "Active",
      "description": "Active projects (Audio, Photo, Visual, VJ, Web)"
    },
    {
      "drive_letter": "L:",
      "target_path": "D:\\_work\\Library",
      "label": "Library",
      "description": "Library - important documents from the work directory"
    },
    {
      "drive_letter": "M:",
      "target_path": "D:\\music",
      "label": "Music",
      "description": "Music library"
    },
    {
      "drive_letter": "P:",
      "target_path": "D:\\_work\\_PIPELINE",
      "label": "Pipeline",
      "description": "Pipeline - scripts and files for software (settings, add-ons)"
    },
    {
      "drive_letter": "F:",
      "target_path": "D:\\personal",
      "label": "Personal",
      "description": "Personal files"
    }
  ],

  "folder_structure": {
    "bases": ["D:\\_work\\Active", "D:\\_work\\Archive"],
    "categories": ["Visual", "RealTime", "Audio", "Physical", "Photo", "Web"],
    "subcategories": {},
    "extra_dirs": [
      "D:\\_work\\_PIPELINE",
      "D:\\_work\\Library",
      "D:\\personal",
      "D:\\music"
    ]
  },

  "_synology_drive_comment": "Synology Drive Client has no CLI / API for creating sync tasks, so setup_environment.py prints a per-task copy-paste card and opens the Drive Client GUI. NO credentials live in this file: 'host' / 'username' are placeholders shown in the card (leave blank to print '<your NAS host>' / '<your username>'); the password is entered once into the GUI, which stores it in Windows Credential Manager. sync_mode: 'two_way' | 'upload_only' | 'download_only'. on_demand: true streams files on access (Files On-Demand) instead of full local sync.",
  "synology_drive": {
    "connection": {
      "host": "",
      "port": 6690,
      "username": ""
    },
    "sync_folders": [
      {
        "name": "Work",
        "local_path": "D:\\_work",
        "remote_path": "/work",
        "sync_mode": "two_way",
        "on_demand": false
      },
      {
        "name": "Personal",
        "local_path": "D:\\personal",
        "remote_path": "/personal",
        "sync_mode": "two_way",
        "on_demand": false
      },
      {
        "name": "Music",
        "local_path": "D:\\music",
        "remote_path": "/music",
        "sync_mode": "two_way",
        "on_demand": false
      }
    ]
  },

  "_workstation_apps_comment": "Apps you may want installed on each PC. The Pipeline does not require any of them - missing entries are non-fatal. category groups them in the picker (accepts a single string like 'Audio' or a list like ['Audio', 'Media'] for apps that belong in multiple sections; the first entry is the 'primary' one). install_method: 'winget' = auto-install via winget; 'manual' = print/open the download URL.",
  "workstation_apps": [
    {
      "name": "KeePassXC",
      "category": "General",
      "install_method": "manual",
      "exe": "KeePassXC",
      "why": "Password manager (settings sync via NAS, not winget)",
      "url": "https://keepassxc.org/download/#windows"
    },
    {
      "name": "Synology Drive Client",
      "category": "General",
      "install_method": "winget",
      "winget_id": "Synology.DriveClient",
      "exe": "SynologyDrive",
      "why": "NAS sync for Active / Archive / Pipeline",
      "url": "https://www.synology.com/en-global/dsm/feature/drive"
    },
    {
      "name": "Visual Subst",
      "category": "General",
      "install_method": "manual",
      "exe": "visualsubst",
      "why": "GUI for the subst drive mappings install.py creates",
      "url": "https://www.ntwind.com/software/visual-subst.html"
    },
    {
      "name": "WizTree",
      "category": "General",
      "install_method": "winget",
      "winget_id": "AntibodySoftware.WizTree",
      "exe": "WizTree",
      "why": "Fast disk space analyzer",
      "url": "https://www.diskanalyzer.com/"
    },
    {
      "name": "LibreOffice",
      "category": "General",
      "install_method": "winget",
      "winget_id": "TheDocumentFoundation.LibreOffice",
