{
  "_comment": "New PC Setup Configuration - Copy to setup_config.json and edit paths to match your system",

  "drive_mappings": [
    {
      "drive_letter": "I:",
      "target_path": "D:\\_work\\Active",
      "description": "Work drive - active projects",
      "registry_name": "SubstDrive_I"
    },
    {
      "drive_letter": "P:",
      "target_path": "D:\\_work\\_PIPELINE",
      "description": "Pipeline drive - scripts, software, launchers",
      "registry_name": "SubstDrive_P"
    }
  ],

  "folder_structure": {
    "bases": ["D:\\_work\\Active", "D:\\_work\\Archive"],
    "categories": ["Visual", "RealTime", "Audio", "Physical", "Photo", "Web"],
    "subcategories": {},
    "extra_dirs": ["D:\\_work\\_PIPELINE"]
  },

  "synology_drive": {
    "sync_folders": [
      { "name": "Active Projects", "expected_path": "D:\\_work\\Active" },
      { "name": "Archive",         "expected_path": "D:\\_work\\Archive" },
      { "name": "Pipeline",        "expected_path": "D:\\_work\\_PIPELINE" }
    ]
  },

  "_workstation_apps_comment": "Apps you want installed on every PC. Pipeline does not require them - missing entries are non-fatal. Add more as needed; install.py just calls winget.",
  "workstation_apps": [
    {
      "name": "KeePassXC",
      "winget_id": "KeePassXCTeam.KeePassXC",
      "exe": "KeePassXC",
      "why": "Password manager",
      "url": "https://keepassxc.org/"
    },
    {
      "name": "Synology Drive Client",
      "winget_id": "Synology.DriveClient",
      "exe": "SynologyDrive",
      "why": "NAS sync for Active / Archive / Pipeline",
      "url": "https://www.synology.com/en-global/dsm/feature/drive",
      "post_install": "launch"
    },
    {
      "name": "Visual Subst",
      "winget_id": "NTWindSoftware.VisualSubst",
      "exe": "visualsubst",
      "why": "GUI for the subst drive mappings install.py creates",
      "url": "https://www.ntwind.com/software/visual-subst.html"
    }
  ],

  "pipeline_config": {
    "work_drive": "I:",
    "active_base": "D:\\_work\\Active",
    "archive_base": "D:\\_work\\Archive",
    "mapped_software_path": "P:\\Software",
    "launchers_base_path": "P:\\Launchers"
  }
}
